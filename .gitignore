# =========================================
# Ignore everything inside UnityProjSoccer/ EXCEPT:
# - Assets/
# - ProjectSettings/  
# - Packages/
# - (and their contents)
# =========================================

# First, ignore everything in UnityProjSoccer
UnityProjSoccer/*

# Then, explicitly allow the important folders
!UnityProjSoccer/Assets/
!UnityProjSoccer/Assets/**/*
!UnityProjSoccer/ProjectSettings/
!UnityProjSoccer/ProjectSettings/**/*
!UnityProjSoccer/Packages/
!UnityProjSoccer/Packages/**/*

# =========================================
# Unity temp/cache files (inside allowed folders)
# =========================================
UnityProjSoccer/*/Library/
UnityProjSoccer/*/Temp/
UnityProjSoccer/*/obj/
UnityProjSoccer/*/Build/
UnityProjSoccer/*/Builds/
UnityProjSoccer/*/UserSettings/
UnityProjSoccer/*/Logs/

# =========================================
# Unity project files (these get regenerated)
# =========================================
UnityProjSoccer/*.sln
UnityProjSoccer/*.csproj
UnityProjSoccer/*.user
UnityProjSoccer/*.userprefs
UnityProjSoccer/*.pidb
UnityProjSoccer/*.booproj
UnityProjSoccer/*.suo
UnityProjSoccer/*.cache
UnityProjSoccer/*.csproj.user
UnityProjSoccer/*.unityproj
UnityProjSoccer/*.prefs
UnityProjSoccer/*.assetproj
UnityProjSoccer/*.sin
UnityProjSoccer/*.pidb.meta
UnityProjSoccer/*.pdb
UnityProjSoccer/*.mdb
UnityProjSoccer/*.pdb.meta

# =========================================
# OS generated files
# =========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
*.tmp
*.log
*.bak

# =========================================
# IDE files
# =========================================
.vs/
.vscode/
.idea/
*.swp
*.swo
*~

# =========================================
# Unity package manager
# =========================================
UnityProjSoccer/Packages/Package-Manager/
UnityProjSoccer/Packages/Assets/