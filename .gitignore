# =========================================
# Ignore everything inside Soccer/ EXCEPT:
# - Assets/
# - ProjectSettings/  
# - Packages/
# - (and their contents)
# =========================================

# First, ignore everything in Soccer
Soccer/*

# Then, explicitly allow the important folders
!Soccer/Assets/
!Soccer/Assets/**/*
!Soccer/ProjectSettings/
!Soccer/ProjectSettings/**/*
!Soccer/Packages/
!Soccer/Packages/**/*

# =========================================
# Unity temp/cache files (inside allowed folders)
# =========================================
Soccer/*/Library/
Soccer/*/Temp/
Soccer/*/obj/
Soccer/*/Build/
Soccer/*/Builds/
Soccer/*/UserSettings/
Soccer/*/Logs/

# =========================================
# Unity project files (these get regenerated)
# =========================================
Soccer/*.sln
Soccer/*.csproj
Soccer/*.user
Soccer/*.userprefs
Soccer/*.pidb
Soccer/*.booproj
Soccer/*.suo
Soccer/*.cache
Soccer/*.csproj.user
Soccer/*.unityproj
Soccer/*.prefs
Soccer/*.assetproj
Soccer/*.sin
Soccer/*.pidb.meta
Soccer/*.pdb
Soccer/*.mdb
Soccer/*.pdb.meta

# =========================================
# OS generated files
# =========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
*.tmp
*.log
*.bak

# =========================================
# IDE files
# =========================================
.vs/
.vscode/
.idea/
*.swp
*.swo
*~

# =========================================
# Unity package manager
# =========================================
Soccer/Packages/Package-Manager/
Soccer/Packages/Assets/